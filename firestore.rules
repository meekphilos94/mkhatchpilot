rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return signedIn() && request.auth.uid == ownerId;
    }

    function isAdmin() {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin']);
    }

    function isLiveListing() {
      return resource.data.status == 'live';
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId);
    }

    match /batches/{batchId} {
      allow read, delete: if isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId)
        && request.resource.data.quantitySet is int
        && request.resource.data.quantitySet > 0
        && request.resource.data.currentDay is int
        && request.resource.data.currentDay >= 0
        && request.resource.data.totalDays is int
        && request.resource.data.totalDays > 0
        && request.resource.data.eggType is string
        && request.resource.data.startDate is string
        && request.resource.data.expectedHatchDate is string
        && request.resource.data.status in ['setup', 'active', 'lockdown', 'hatched', 'archived'];
      allow update: if isOwner(resource.data.ownerId)
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.quantitySet is int
        && request.resource.data.quantitySet > 0
        && request.resource.data.currentDay is int
        && request.resource.data.currentDay >= 0
        && request.resource.data.totalDays is int
        && request.resource.data.totalDays > 0
        && request.resource.data.status in ['setup', 'active', 'lockdown', 'hatched', 'archived'];
    }

    match /dailyLogs/{logId} {
      allow read, delete: if isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId)
        && request.resource.data.batchId is string
        && request.resource.data.dayNumber is int
        && request.resource.data.dayNumber > 0
        && request.resource.data.temperatureC is number
        && request.resource.data.humidityPercent is number
        && request.resource.data.eggsTurned is bool
        && request.resource.data.waterAdded is bool
        && request.resource.data.loggedAt is string;
      allow update: if isOwner(resource.data.ownerId)
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.batchId == resource.data.batchId
        && request.resource.data.dayNumber is int
        && request.resource.data.dayNumber > 0
        && request.resource.data.temperatureC is number
        && request.resource.data.humidityPercent is number
        && request.resource.data.eggsTurned is bool
        && request.resource.data.waterAdded is bool;
    }

    match /candlingRecords/{recordId} {
      allow read, delete: if isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId)
        && request.resource.data.batchId is string
        && request.resource.data.dayNumber is int
        && request.resource.data.dayNumber > 0
        && request.resource.data.fertileCount is int
        && request.resource.data.fertileCount >= 0
        && request.resource.data.clearCount is int
        && request.resource.data.clearCount >= 0
        && request.resource.data.removedCount is int
        && request.resource.data.removedCount >= 0
        && request.resource.data.createdAt is string;
      allow update: if false;
    }

    match /marketplaceListings/{listingId} {
      allow read: if isOwner(resource.data.sellerId) || isLiveListing();
      allow delete: if isOwner(resource.data.sellerId);
      allow create: if isOwner(request.resource.data.sellerId)
        && request.resource.data.title is string
        && request.resource.data.category in ['chicks', 'fertile-eggs', 'birds', 'equipment']
        && request.resource.data.quantity is int
        && request.resource.data.quantity > 0
        && request.resource.data.price is number
        && request.resource.data.location is string
        && request.resource.data.status in ['draft', 'live', 'sold']
        && request.resource.data.createdAt is string;
      allow update: if isOwner(resource.data.sellerId)
        && request.resource.data.sellerId == resource.data.sellerId
        && request.resource.data.category in ['chicks', 'fertile-eggs', 'birds', 'equipment']
        && request.resource.data.quantity is int
        && request.resource.data.quantity > 0
        && request.resource.data.price is number
        && request.resource.data.status in ['draft', 'live', 'sold'];
    }

    match /listingInquiries/{inquiryId} {
      allow read: if isOwner(resource.data.sellerId) || isOwner(resource.data.buyerId);
      allow create: if signedIn()
        && request.resource.data.buyerId == request.auth.uid
        && request.resource.data.sellerId is string
        && request.resource.data.listingId is string
        && request.resource.data.listingTitle is string
        && request.resource.data.participantIds is list
        && request.resource.data.buyerName is string
        && request.resource.data.message is string
        && request.resource.data.status in ['new', 'contacted', 'closed']
        && request.resource.data.createdAt is string;
      allow update: if isOwner(resource.data.sellerId)
        && request.resource.data.sellerId == resource.data.sellerId
        && request.resource.data.buyerId == resource.data.buyerId
        && request.resource.data.status in ['new', 'contacted', 'closed'];
      allow delete: if isOwner(resource.data.sellerId);
    }

    match /marketplaceMessages/{messageId} {
      allow read: if signedIn() && resource.data.participantIds.hasAny([request.auth.uid]);
      allow create: if signedIn()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.participantIds is list
        && request.resource.data.participantIds.hasAny([request.auth.uid])
        && request.resource.data.threadId is string
        && request.resource.data.listingId is string
        && request.resource.data.sellerId is string
        && request.resource.data.buyerId is string
        && request.resource.data.senderName is string
        && request.resource.data.senderRole in ['buyer', 'seller']
        && request.resource.data.message is string
        && request.resource.data.createdAt is string;
      allow update, delete: if false;
    }

    match /savedMarketplaceListings/{savedListingId} {
      allow read, delete: if isOwner(resource.data.ownerId);
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.listingId is string
        && request.resource.data.createdAt is string;
      allow update: if false;
    }

    match /sellerVerificationRequests/{requestId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.fullName is string
        && request.resource.data.phoneNumber is string
        && request.resource.data.location is string
        && request.resource.data.businessType in ['farm', 'hatchery', 'trader']
        && request.resource.data.idDocumentReady is bool
        && request.resource.data.proofOfLocationReady is bool
        && request.resource.data.submittedAt is string
        && request.resource.data.status in ['submitted', 'approved', 'rejected'];
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.status in ['submitted', 'approved', 'rejected'];
      allow delete: if false;
    }
  }
}
